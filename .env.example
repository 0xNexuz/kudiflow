# Celo mainnet is required by the hackathon.
CELO_NETWORK=celo-mainnet
CELO_RPC_URL=https://forno.celo.org

# Server-only agent/deployer wallet. Never expose this through a public variable.
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# Assigned by Celo Builders registration. Required before tagged settlement.
CELO_BUILDERS_ATTRIBUTION_TAG=

# x402 on Celo.
X402_FACILITATOR_URL=https://x402.celo.org
X402_STOCK_SERVICE_URL=
X402_DELIVERY_SERVICE_URL=
X402_RISK_SERVICE_URL=
X402_STOCK_PRICE_USDC=0.001
X402_DELIVERY_PRICE_USDC=0.002
X402_RISK_PRICE_USDC=0.004
X402_STOCK_PAYTO=
X402_DELIVERY_PAYTO=
X402_RISK_PAYTO=

# Settlement destinations on Celo mainnet.
SUPPLIER_ADDRESS=
KUDIFLOW_FEE_RECIPIENT=
